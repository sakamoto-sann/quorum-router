# Supabase audit RPC runtime config.
# Keep example values empty. Inject real values from a secret manager or deployment
# environment, never from committed files.

# Prefer the FUSION_ROUTER_* names for this repo.
FUSION_ROUTER_SUPABASE_URL=
FUSION_ROUTER_SUPABASE_ANON_KEY=

# Optional fallback names recognized by doctor/runtime integrations that already
# standardize on SUPABASE_*.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# User/session JWTs are request-scoped credentials. Do not commit them here.
# Pass them to createSupabaseAuditHandler({ jwtProvider }) from the active
# gateway/session context.

# Do not add service-role Supabase credentials to this file or to the router
# runtime environment. Service-role credentials are migration/admin-only.
