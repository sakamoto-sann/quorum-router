{
  "lock": "deno.lock",
  "imports": {
    "@std/assert": "https://deno.land/std@0.224.0/assert/mod.ts",
    "@std/testing/time": "https://deno.land/std@0.224.0/testing/time.ts",
    "zod": "https://deno.land/x/zod@v3.23.8/mod.ts"
  },
  "tasks": {
    "check": "deno check router.ts router_test.ts doctor.ts",
    "fmt": "deno fmt router.ts router_test.ts doctor.ts README.md deno.json",
    "lint": "deno lint router.ts router_test.ts doctor.ts",
    "test": "deno test -A router_test.ts",
    "run": "deno run --allow-run --allow-read --allow-write --allow-env --allow-net router.ts",
    "doctor": "deno run --allow-env --allow-run doctor.ts",
    "lock": "deno cache --lock=deno.lock router.ts router_test.ts doctor.ts",
    "lock:check": "deno cache --lock=deno.lock --frozen router.ts router_test.ts doctor.ts"
  }
}
